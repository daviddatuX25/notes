---
layout: layouts/base.njk
---

<article class="post {% if isPrivate %}post-private{% endif %}">
  <h1 class="post-title">
    {{ title }}
    {% if isPrivate %}<span class="private-badge" title="This post is behind HTTP basic auth">protected</span>{% endif %}
  </h1>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <hr class="post-divider" />
    <div class="post-meta">
      <span class="post-date">{{ date | readableDate }}</span>
      {% if tags and tags.length %}
        <span class="post-tags">
          {% for tag in tags | filterTagList %}
            <a href="/tags/{{ tag | slugify }}/" class="tag-link">#{{ tag }}</a>
          {% endfor %}
        </span>
      {% endif %}
    </div>
    <div class="post-actions">
      <a href="{{ page.url }}" class="permalink" title="Copy permalink">permalink</a>
    </div>
  </footer>
</article>

{% set posts = collections.posts %}
{% set currentIndex = -1 %}
{% for post in posts %}
  {% if post.url == page.url %}
    {% set currentIndex = loop.index0 %}
  {% endif %}
{% endfor %}

{% if currentIndex >= 0 %}
  <nav class="post-nav-links" data-post-nav>
    {% if posts[currentIndex + 1] %}
      <a href="{{ posts[currentIndex + 1].url }}" class="post-nav-prev" rel="prev">
        ← {{ posts[currentIndex + 1].data.title }}
      </a>
    {% endif %}
    {% if posts[currentIndex - 1] %}
      <a href="{{ posts[currentIndex - 1].url }}" class="post-nav-next" rel="next">
        {{ posts[currentIndex - 1].data.title }} →
      </a>
    {% endif %}
  </nav>
{% endif %}
